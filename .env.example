# ══════════════════════════════════════════════════════════
# TRADING BOT - OPTIONS TRADING CONFIGURATION
# ══════════════════════════════════════════════════════════


# ──────────────────────────────────────
# ENVIRONMENT
# ──────────────────────────────────────
ENVIRONMENT=development
DEBUG=true


# ──────────────────────────────────────
# TRADING MODE
# ──────────────────────────────────────
PAPER_TRADING=true
TRADING_TYPE=OPTIONS


# ──────────────────────────────────────
# DHAN BROKER API
# ──────────────────────────────────────
DHAN_CLIENT_ID=*************
DHAN_ACCESS_TOKEN=****************

# ──────────────────────────────────────
# FINNHUB NEWS API
# ──────────────────────────────────────
FINNHUB_API_KEY=********************


# ──────────────────────────────────────
# TELEGRAM BOT
# ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=GYELEGRAM_CHAT_ID=*************************
TELEGRAM_ADMIN_IDS=*********************


# ──────────────────────────────────────
# DATABASE
# ──────────────────────────────────────
DATABASE_URL=sqlite:///trading_bot.db


# ──────────────────────────────────────
# CAPITAL & POSITION MANAGEMENT
# ──────────────────────────────────────
INITIAL_CAPITAL=10000
MAX_CAPITAL_PER_TRADE=2500
MAX_OPEN_POSITIONS=4
MAX_TRADES_PER_DAY=20
MAX_DAILY_LOSS=0.03


# ──────────────────────────────────────
# OPTIONS SPECIFIC SETTINGS
# ──────────────────────────────────────
# What to trade
OPTIONS_INSTRUMENTS=NIFTY,BANKNIFTY

# Lot sizes (fixed by exchange)
NIFTY_LOT_SIZE=25
BANKNIFTY_LOT_SIZE=15

# Max lots per trade
MAX_LOTS_PER_TRADE=1

# Which expiry to trade
PREFERRED_EXPIRY=WEEKLY

# Strike selection
# ATM = At the money
# OTM1 = 1 strike out of money
# OTM2 = 2 strikes out of money
PREFERRED_STRIKE=ATM

# Premium limits
MAX_PREMIUM_PER_LOT=250
MIN_PREMIUM_PER_LOT=20

# Auto-close before expiry
CLOSE_BEFORE_EXPIRY_HOURS=2

# Don't buy if IV is too high
MAX_IV_THRESHOLD=30


# ──────────────────────────────────────
# RISK MANAGEMENT
# ──────────────────────────────────────
STOP_LOSS_PERCENTAGE=30.0
TAKE_PROFIT_PERCENTAGE=50.0
TRAILING_STOP_PERCENTAGE=20.0
MAX_CONSECUTIVE_LOSSES=5
CIRCUIT_BREAKER_COOLDOWN=3600


# ──────────────────────────────────────
# MARKET TIMING (IST)
# ──────────────────────────────────────
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
# Don't take new trades after this time
NO_NEW_TRADES_AFTER=14:30
# Close all positions by this time
CLOSE_ALL_POSITIONS_BY=15:15
SCAN_INTERVAL=30


# ──────────────────────────────────────
# BRAIN WEIGHTS (must sum to 1.0)
# ──────────────────────────────────────
BRAIN_WEIGHT_TECHNICAL=0.40
BRAIN_WEIGHT_SENTIMENT=0.35
BRAIN_WEIGHT_PATTERN=0.25


# ──────────────────────────────────────
# LOGGING
# ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=logs/bot.log
